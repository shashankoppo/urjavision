# URJA VISION - Environment Configuration Example
# Copy this file to .env and fill in your values

# Application
VITE_APP_NAME=URJA VISION
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:5173

# API Configuration (for future backend integration)
VITE_API_URL=https://api.yourdomain.com
VITE_API_TIMEOUT=30000

# Contact Information
VITE_COMPANY_PHONE=+91 72473 91595
VITE_COMPANY_EMAIL=info@urjavision.com

# Social Media
VITE_FACEBOOK_URL=https://facebook.com/urjavision
VITE_INSTAGRAM_URL=https://instagram.com/urjavision
VITE_LINKEDIN_URL=https://linkedin.com/company/urjavision
VITE_TWITTER_URL=https://twitter.com/urjavision

# Third Party Services (Optional)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_SENTRY_DSN=your-sentry-dsn
VITE_ANALYTICS_ID=your-analytics-id

# Feature Flags
VITE_ENABLE_CALCULATOR=true
VITE_ENABLE_NEWSLETTER=true
VITE_ENABLE_CONTACT_FORM=true
VITE_ENABLE_ANIMATIONS=true

# Debug Mode
VITE_DEBUG=false
